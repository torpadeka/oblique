# ── Terminal 3 Network ──
# T3N_API_KEY is a WALLET PRIVATE KEY (claim one at https://terminal3.io). Keep it secret.
T3N_API_KEY=0x...
T3N_DID=did:t3n:...
T3N_ENV=testnet
# Distinct identity for the agent that acts on the user's behalf (openssl rand -hex 32).
T3N_AGENT_KEY=0x...

# ── QVAC document ingestion (optional — on-device PDF → JSON) ──
# Read by the Next app. QVAC_BASE_URL must point at a LOCAL / on-device QVAC
# runtime exposing an OpenAI-compatible /chat/completions endpoint, so raw
# documents (PII) are parsed on the machine and never sent to a cloud model.
# Omit to use the built-in deterministic local heuristic parser instead.
# Run the bundled sidecar with `npm run qvac:serve` (see vars below).
QVAC_BASE_URL=          # e.g. http://localhost:8787/v1
QVAC_MODEL=qvac-local
QVAC_API_KEY=           # only if your local runtime requires one

# ── QVAC sidecar (scripts/qvac-server.mjs — wraps @qvac/sdk over HTTP) ──
# These are read by the sidecar process, not the app. `npm run qvac:serve`
# loads them from this file via node --env-file.
QVAC_MODEL_SRC=QWEN3_4B_INST_Q4_K_M   # model registry export; 1B default is weak at 36-field JSON
QVAC_CTX_SIZE=8192                     # context window; SDK default 1024 truncates multi-page PDFs
QVAC_PORT=8787                         # must match the port in QVAC_BASE_URL above
# OCR fallback for SCANNED PDFs (no text layer). Model loads lazily on first use.
# onnx = fast (~1s/pg) but garbles dense text/numbers. vlm = near-perfect transcription
# but slow (~100s/pg on CPU-class HW) + ~1 GB download. Pre-warm vlm after boot.
QVAC_OCR_MODE=vlm
QVAC_OCR_MAX_PAGES=10                 # page cap per document
QVAC_OCR_SCALE=3                      # page raster scale (higher = sharper text, slower)
# onnx mode:
QVAC_OCR_MODEL_SRC=OCR_LATIN_RECOGNIZER_1  # recognizer; detector auto-bundled via langs
QVAC_OCR_LANGS=en                     # comma-separated OCR languages
QVAC_OCR_GPU=1                        # OCR on GPU; set 0 to force CPU if it errors
# vlm mode (multimodal OCR LLM — ~1 GB+ download on first use):
QVAC_OCR_VLM_SRC=OCR_0_6B_MULTIMODAL_Q4_K_M
QVAC_OCR_VLM_MMPROJ=MMPROJ_OCR_0_6B_MULTIMODAL_F16
QVAC_OCR_VLM_CTX=4096

# ── OpenRouter (optional — LLM credit analyst) ──
# Omit to use the built-in rule-based opinion. NOTE: OpenRouter only ever receives
# the DE-IDENTIFIED features (ratios + score), never raw PII or the documents.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
OPENROUTER_SITE_URL=http://localhost:3000
